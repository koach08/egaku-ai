# AI Studio Local (Self-Hosted) Mode
MODE=local

# ComfyUI (must be running on your machine)
LOCAL_COMFYUI_URL=http://127.0.0.1:8188

# Output directory for generated images/videos
LOCAL_OUTPUT_DIR=./outputs

# Models directory (your ComfyUI models folder)
LOCAL_MODELS_DIR=./models

# License key (purchased from AI Studio)
LICENSE_KEY=your-license-key

# Optional: CivitAI API key for model downloads
CIVITAI_API_KEY=
